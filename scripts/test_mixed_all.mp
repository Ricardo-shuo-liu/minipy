# 变量定义
num1 = 100;
num2 = 25;

# 四则混合运算
calc = (num1 + num2) * 2 / 5;
print(calc);

# 判断分支
flag = 1;
if (flag == 1) {
    a = 10;
    b = 20;
    print(a + b);
} else {
    print(0);
}

# 循环累加
total = 0;
k = 1;
while (k < 6) {
    total = total + k;
    k = k + 1;
}
print(total);

# 多层括号嵌套
val = ((1 + 3) * (10 - 2)) / 4;
print(val);
